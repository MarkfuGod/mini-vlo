        \centering 

        \includegraphics[width=4.5cm]{hku_logo.png} \par
        \vspace{0.8cm}

        {\large The University of Hong Kong \par}
        \vspace{0.2cm}
        {\large School of Computing and Data Science \par}

        \vspace{2.5cm} 

        {\large COMP7705 \par}
        \vspace{0.2cm}
